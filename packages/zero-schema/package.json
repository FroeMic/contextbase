{
  "name": "@contextbase/zero-schema",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/packages/zero-schema/src/index.d.ts",
      "default": "./dist/packages/zero-schema/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/fix-esm-imports.mjs dist",
    "generate": "drizzle-zero generate --config drizzle-zero.config.ts --schema ../core/src/db/schema.ts --output src/generated-schema.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@rocicorp/zero": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.9.1",
    "drizzle-zero": "^0.18.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
