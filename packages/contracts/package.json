{
  "name": "@contextbase/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./domains/users/contract": {
      "types": "./dist/domains/users/contract.d.ts",
      "default": "./dist/domains/users/contract.js"
    },
    "./domains/invitations/contract": {
      "types": "./dist/domains/invitations/contract.d.ts",
      "default": "./dist/domains/invitations/contract.js"
    },
    "./domains/workspace-members/contract": {
      "types": "./dist/domains/workspace-members/contract.d.ts",
      "default": "./dist/domains/workspace-members/contract.js"
    },
    "./domains/workspaces/contract": {
      "types": "./dist/domains/workspaces/contract.d.ts",
      "default": "./dist/domains/workspaces/contract.js"
    },
    "./shared/envelopes": {
      "types": "./dist/shared/envelopes.d.ts",
      "default": "./dist/shared/envelopes.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/fix-esm-imports.mjs dist",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "effect": "3.19.6"
  },
  "devDependencies": {
    "@types/node": "24.9.1",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
