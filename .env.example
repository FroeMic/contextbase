# Core database
DATABASE_URL=postgres://contextbase:contextbase_dev_only@127.0.0.1:5417/contextbase

# Local service ports
POSTGRES_HOST_PORT=5417
API_HOST_PORT=3017
WEB_HOST_PORT=4017
ZERO_HOST_PORT=4817
AUTH_HOST_PORT=3317
MCP_HOST_PORT=3217

# API service
API_HOST=0.0.0.0
API_PORT=3017
CONTEXTBASE_API_URL=http://127.0.0.1:3017
CONTEXTBASE_API_RESOURCE_URL=http://127.0.0.1:3017/api/v1
CONTEXTBASE_API_TOKEN=

# Web/auth/MCP services
AUTH_HOST=0.0.0.0
AUTH_PORT=3317
AUTH_PUBLIC_BASE_URL=http://127.0.0.1:3317
AUTH_COOKIE_DOMAIN=
CONTEXTBASE_AUTH_BASE_URL=http://127.0.0.1:3317
CONTEXTBASE_WEB_BASE_URL=http://127.0.0.1:4017
CONTEXTBASE_APP_BASE_URL=http://127.0.0.1:4017
MCP_HOST=0.0.0.0
MCP_PORT=3217
MCP_PUBLIC_BASE_URL=http://127.0.0.1:3217
CONTEXTBASE_MCP_RESOURCE_URL=http://127.0.0.1:3217/mcp

# Files
CONTEXTBASE_PUBLIC_ASSETS_BASE_URL=http://127.0.0.1:4017/public
CONTEXTBASE_UPLOADS_PUBLIC_BASE_URL=http://127.0.0.1:4017/api/files
CONTEXTBASE_UPLOADS_INTERNAL_BASE_URL=http://web:4017/api/files
CONTEXTBASE_STORAGE_PROVIDER=local_disk
CONTEXTBASE_STORAGE_LOCAL_DIR=/data/uploads
CONTEXTBASE_STORAGE_S3_BUCKET=
CONTEXTBASE_STORAGE_S3_ENDPOINT=
CONTEXTBASE_STORAGE_S3_FORCE_PATH_STYLE=false
CONTEXTBASE_STORAGE_S3_PREFIX=
CONTEXTBASE_STORAGE_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Zero
ZERO_ADMIN_PASSWORD=contextbase_zero_dev_only
VITE_ZERO_CACHE_URL=

# Email notifications
AGENTMAIL_API_KEY=
AGENTMAIL_FROM_NAME=Contextbase
AGENTMAIL_INBOX_ID=
WAITLIST_NOTIFICATION_RECIPIENTS=

# Analytics
POSTHOG_ENABLED=false
POSTHOG_ENVIRONMENT=development
POSTHOG_TOKEN=
POSTHOG_HOST=/ingest
POSTHOG_BROWSER_HOST=/ingest
POSTHOG_PROXY_TARGET=https://eu.i.posthog.com
POSTHOG_ASSET_PROXY_TARGET=https://eu-assets.i.posthog.com
POSTHOG_SERVICE_VERSION=
POSTHOG_FLUSH_TIMEOUT_MS=500

# Web limits
WEB_AUTH_RATE_LIMIT_MAX=20
WEB_AUTH_RATE_LIMIT_WINDOW_MS=60000
WEB_MAX_JSON_BODY_BYTES=262144
WEB_ALLOWED_HOSTS=
WEB_HMR_HOST=

# Local-domain / portless development
LOCAL_DOMAINS_CADDY_PORT=8217
LOCAL_AUTH_BASE_URL=https://contextbase-2.test
LOCAL_API_BASE_URL=https://api.contextbase-2.test
LOCAL_API_RESOURCE_URL=https://api.contextbase-2.test/api/v1
LOCAL_MCP_BASE_URL=https://contextbase-2.test
LOCAL_APP_BASE_URL=https://contextbase-2.test
LOCAL_PUBLIC_ASSETS_BASE_URL=https://contextbase-2.test/public
LOCAL_UPLOADS_BASE_URL=https://uploads.contextbase-2.test
LOCAL_ZERO_BASE_URL=https://zero.contextbase-2.test
LOCAL_AUTH_COOKIE_DOMAIN=.contextbase-2.test
LOCAL_WEB_ALLOWED_HOSTS=contextbase-2.test,uploads.contextbase-2.test
LOCAL_APP_HOST=contextbase-2.test
LOCAL_API_HOST=api.contextbase-2.test
LOCAL_UPLOADS_HOST=uploads.contextbase-2.test
LOCAL_ZERO_HOST=zero.contextbase-2.test
LOCAL_CONSOLE_HOST=console.contextbase-2.test
PORTLESS_PORT=443
